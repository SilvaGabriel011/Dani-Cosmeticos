# Database (Neon PostgreSQL)
# For Neon with connection pooling (recommended for serverless environments like Vercel):
# - Use the pooled connection string (with -pooler in the hostname)
# - Add connect_timeout=15 to handle cold starts
# - sslmode=require is required for Neon
DATABASE_URL="postgresql://user:password@ep-example-123456-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# ── Automatic Neon Backup (Vercel Cron → /api/backup/auto) ──────────────
# These variables are required for the daily automatic backup that creates
# Neon branches as point-in-time snapshots. Without them the cron will
# return 503.
#
# NEON_API_KEY:    Create at https://console.neon.tech → Account Settings → API Keys
# NEON_PROJECT_ID: Found in the Neon project dashboard URL or Settings page
# CRON_SECRET:     Any random string. Set it both here and in vercel.json (Vercel
#                  sends it as "Authorization: Bearer <secret>" to authenticate cron requests)
NEON_API_KEY=""
NEON_PROJECT_ID=""
CRON_SECRET=""
